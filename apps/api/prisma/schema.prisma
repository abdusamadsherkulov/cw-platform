// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      String   @default("candidate")
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  attributeValues AttributeValue[]
  cvs CV[]
  projects Project[]
  discussionPosts DiscussionPost[]
  likesGiven CVLike[]
}

model Attribute {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  type        String
  categoryId  Int
  category    AttributeCategory @relation(fields: [categoryId], references: [id])
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  positionLinks PositionAttribute[]
  accessRuleLinks PositionAccessRule[]
  valueLinks AttributeValue[]
}

model AttributeCategory {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  attributes Attribute[]
}

model Position {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attributes  PositionAttribute[]
  accessRules PositionAccessRule[]
  projectTags   String[]
  maxProjects   Int      @default(3)
  cvs CV[]
  discussionPosts DiscussionPost[]
}

model PositionAttribute {
  id          Int       @id @default(autoincrement())
  positionId  Int
  position    Position  @relation(fields: [positionId], references: [id])
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
}

model PositionAccessRule {
  id          Int       @id @default(autoincrement())
  positionId  Int
  position    Position  @relation(fields: [positionId], references: [id])
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  operator    String
  value       String
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  value       String
  version     Int       @default(1)

  @@unique([userId, attributeId])
}

model CV {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  positionId Int
  position   Position @relation(fields: [positionId], references: [id])
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  likes CVLike[]

  @@unique([userId, positionId])
}

model Project {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  name        String
  startDate   DateTime
  endDate     DateTime?
  description String
  tags        String[]
  createdAt   DateTime @default(now())
}

model DiscussionPost {
  id         Int      @id @default(autoincrement())
  positionId Int
  position   Position @relation(fields: [positionId], references: [id])
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
}

model CVLike {
  id          Int      @id @default(autoincrement())
  cvId        Int
  cv          CV       @relation(fields: [cvId], references: [id])
  recruiterId Int
  recruiter   User     @relation(fields: [recruiterId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([cvId, recruiterId])
}